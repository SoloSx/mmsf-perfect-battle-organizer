  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check": "pnpm lint && pnpm build",
    "check:auto": "sh ./scripts/check-auto.sh",
    "review:react-best-practices": "pnpm lint && pnpm build && pnpm review:react-best-practices:report",
